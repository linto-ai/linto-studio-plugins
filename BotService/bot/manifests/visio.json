{
  "platformType": "sfu",
  "diarizationMode": "native",
  "loginRules": [
    {
      "action": "fill",
      "selector": "input[type='text']",
      "value": "{{botName}}",
      "timeout": 30000
    },
    {
      "action": "click",
      "selector": "button[type='submit']",
      "timeout": 10000
    }
  ],
  "leaveRules": [
    {
      "action": "click",
      "selector": "[data-attr='controls-leave']",
      "timeout": 5000,
      "optional": true
    },
    {
      "action": "waitForTimeout",
      "timeout": 2000,
      "optional": true
    }
  ]
}
