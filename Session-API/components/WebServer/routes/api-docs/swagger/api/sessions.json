{
  "/sessions/purge": {
    "post": {
      "tags": [
        "sessions"
      ],
      "operationId": "purgeSessions",
      "summary": "Purge terminated sessions or all sessions if force is true",
      "parameters": [
        {
          "in": "query",
          "name": "force",
          "description": "Force deletion of all sessions",
          "required": false,
          "schema": {
            "type": "boolean"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Sessions purged successfully"
        }
      }
    }
  },
  "/sessions": {
    "get": {
      "tags": [
        "sessions"
      ],
      "operationId": "listSessions",
      "summary": "Get all sessions",
      "parameters": [
        {
          "in": "query",
          "name": "limit",
          "description": "Maximum number of sessions in the answer",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "in": "query",
          "name": "offset",
          "description": "Offset from the start the number of sessions",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "in": "query",
          "name": "searchName",
          "description": "Name of the session to search",
          "required": false,
          "schema": {
            "type": "string"
          }
        },
        {
          "in": "query",
          "name": "statusList",
          "description": "Session status to search for. Multiple statuses can be specified, separated by a comma.",
          "required": false,
          "schema": {
            "type": "string"
          }
        },
        {
          "in": "query",
          "name": "organizationId",
          "description": "Search for sessions belonging to this organization.",
          "required": false,
          "schema": {
            "type": "string"
          }
        },
        {
          "in": "query",
          "name": "visibility",
          "description": "Search for sessions with a specific visibility.",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "private",
              "organization",
              "public",
              "user"
            ]
          }
        },
        {
          "in": "query",
          "name": "excludeVisibility",
          "description": "Exclude sessions with a specific visibility.",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "private",
              "organization",
              "public",
              "user"
            ]
          }
        },
        {
          "name": "scheduleOn[before]",
          "in": "query",
          "description": "Filter items scheduled before the specified date.",
          "required": false,
          "schema": {
            "type": "string",
            "format": "date"
          }
        },
        {
          "name": "scheduleOn[after]",
          "in": "query",
          "description": "Filter items scheduled after the specified date.",
          "required": false,
          "schema": {
            "type": "string",
            "format": "date"
          }
        },
        {
          "name": "endOn[before]",
          "in": "query",
          "description": "Filter items ending before the specified date.",
          "required": false,
          "schema": {
            "type": "string",
            "format": "date"
          }
        },
        {
          "name": "endOn[after]",
          "in": "query",
          "description": "Filter items ending after the specified date.",
          "required": false,
          "schema": {
            "type": "string",
            "format": "date"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "The list of sessions",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionPaginationAnswer"
              }
            }
          }
        }
      }
    },
    "post": {
      "tags": [
        "sessions"
      ],
      "operationId": "createSession",
      "summary": "Create a new session",
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/SessionRequest"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "OK",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswer"
              }
            }
          }
        },
        "400": {
          "$ref": "#/components/responses/BadRequest"
        }
      }
    }
  },
  "/sessions/{id}": {
    "get": {
      "tags": [
        "sessions"
      ],
      "operationId": "getSession",
      "summary": "Get a session by ID",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Session ID",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "withCaptions",
          "in": "query",
          "description": "Include closedCaptions and translatedCaptions in the response",
          "required": false,
          "schema": {
            "type": "boolean",
            "default": true
          }
        }
      ],
      "responses": {
        "200": {
          "description": "The session",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswerWithCaptions"
              }
            }
          }
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    },
    "put": {
      "tags": [
        "sessions"
      ],
      "operationId": "updateSession",
      "summary": "Update a session and its channels",
      "description": "Replaces the session and its channels. Only the fields exposed by SessionUpdateRequestWithChannels are honored — system-managed fields (status, startTime, endTime, pausedAt, erroredOn, id, createdAt, updatedAt) are silently dropped to prevent clients from bypassing the dedicated lifecycle endpoints (/pause, /resume, /stop). Refused with 400 if startTime is in the past.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Session ID",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/SessionUpdateRequestWithChannels"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "OK",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswer"
              }
            }
          }
        },
        "400": {
          "$ref": "#/components/responses/BadRequest"
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    },
    "patch": {
      "tags": [
        "sessions"
      ],
      "operationId": "patchSession",
      "summary": "Update a session",
      "description": "Partial update. Only the fields exposed by SessionUpdateRequest are honored — system-managed fields (status, startTime, endTime, pausedAt, erroredOn, id, createdAt, updatedAt) are silently dropped.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Session ID",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/SessionUpdateRequest"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "OK",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswer"
              }
            }
          }
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    },
    "delete": {
      "tags": [
        "sessions"
      ],
      "operationId": "deleteSession",
      "summary": "Delete a session by ID",
      "description": "Deletes the session row and cascades to its channels. Active and paused sessions are refused with 400 unless ?force=true is set, to prevent accidental loss of an in-flight session.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Session ID",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "in": "query",
          "name": "force",
          "description": "Force session stop",
          "required": false,
          "schema": {
            "type": "boolean"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Session successfully deleted"
        },
        "400": {
          "$ref": "#/components/responses/BadRequest"
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    }
  },
  "/sessions/{id}/channels/{channelId}": {
    "get": {
      "tags": [
        "sessions"
      ],
      "operationId": "getSessionChannel",
      "summary": "Get a single channel of a session with paginated captions",
      "description": "Returns a single channel with reverse-paginated closedCaptions and translatedCaptions. offset=0 returns the N most recent turns, offset=50 returns the 50 before that, etc. Within a page, turns are in chronological order (oldest first).",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Session ID",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "channelId",
          "in": "path",
          "description": "Channel ID",
          "required": true,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "limit",
          "in": "query",
          "description": "Maximum number of turns to return",
          "required": false,
          "schema": {
            "type": "integer",
            "default": 50
          }
        },
        {
          "name": "offset",
          "in": "query",
          "description": "Number of turns to skip from the end (reverse pagination)",
          "required": false,
          "schema": {
            "type": "integer",
            "default": 0
          }
        }
      ],
      "responses": {
        "200": {
          "description": "The channel with paginated captions",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChannelAnswerWithPaginatedCaptions"
              }
            }
          }
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    }
  },
  "/sessions/{id}/stop": {
    "put": {
      "tags": [
        "sessions"
      ],
      "operationId": "stopSession",
      "summary": "Stop a session by ID",
      "description": "Terminates the session and marks all its channels inactive. Active and paused sessions are refused with 400 unless ?force=true is set (so that an operator who issues a stop on a live session has to confirm the data-loss intent).",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Session ID",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "in": "query",
          "name": "force",
          "description": "Force session stop",
          "required": false,
          "schema": {
            "type": "boolean"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "The session",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswer"
              }
            }
          }
        },
        "400": {
          "$ref": "#/components/responses/BadRequest"
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    }
  },
  "/sessions/{id}/pause": {
    "put": {
      "tags": [
        "sessions"
      ],
      "operationId": "pauseSession",
      "summary": "Pause an active session",
      "description": "Transitions the session status from 'active' to 'paused'. The audio stream stays open and is drained, but ASR is fully stopped to release resources. Idempotent: re-issuing on a paused session returns 200 unchanged and does not republish the sessions/paused MQTT event.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Session paused (or already paused, idempotent)",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswer"
              }
            }
          }
        },
        "400": {
          "$ref": "#/components/responses/BadRequest"
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    }
  },
  "/sessions/{id}/resume": {
    "put": {
      "tags": [
        "sessions"
      ],
      "operationId": "resumeSession",
      "summary": "Resume a paused session",
      "description": "Transitions the session status from 'paused' back to 'active'. ASR is restarted. Idempotent: re-issuing on an active session returns 200 unchanged and does not republish the sessions/resumed MQTT event.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Session resumed (or already active, idempotent)",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswer"
              }
            }
          }
        },
        "400": {
          "$ref": "#/components/responses/BadRequest"
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    }
  },
  "/sessions/{id}/clear": {
    "put": {
      "tags": [
        "sessions"
      ],
      "operationId": "clearSession",
      "summary": "Clear all transcriptions and translations of a session",
      "description": "Wipes every Caption and TranslatedCaption row attached to the session's channels and resets each channel's lastSegmentId cursor to 0. The session status is left unchanged (the audio stream and ASR keep running on an active session). Intended for the case where a meeting is recorded but only the formal start is meaningful — operators trigger /clear once everyone is settled and the real meeting begins. Allowed in statuses 'ready', 'active' and 'paused'; refused with 400 for 'on_schedule' (nothing to clear) and 'terminated' (immutable archive). Best-effort: captions emitted by an in-flight ASR within a few hundred milliseconds of the call may still land after the wipe. If the ASR is currently running, its in-process segmentId counter is not reset; new captions written after /clear will continue from the previous counter even though channel.lastSegmentId is now 0. Stop and restart the channel (or the session) if a clean restart from segmentId=1 is required.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Session cleared",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswerWithCaptions"
              }
            }
          }
        },
        "400": {
          "$ref": "#/components/responses/BadRequest"
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        }
      }
    }
  },
  "/sessions/{id}/delete-captions": {
    "delete": {
      "tags": [
        "sessions"
      ],
      "operationId": "deleteSessionCaptions",
      "summary": "Delete captions of a session by ID",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Session ID",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "in": "query",
          "name": "start_time",
          "description": "Delete captions from this time",
          "required": false,
          "schema": {
            "type": "string",
            "format": "time",
            "example": "00:00:00",
            "default": null
          }
        },
        {
          "in": "query",
          "name": "end_time",
          "description": "Delete captions to this time",
          "required": false,
          "schema": {
            "type": "string",
            "format": "time",
            "example": "00:05:00",
            "default": null
          }
        }
      ],
      "responses": {
        "200": {
          "description": "The session",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionAnswerWithCaptions"
              }
            }
          }
        },
        "404": {
          "$ref": "#/components/responses/NotFound"
        },
        "400": {
          "description": "Bad Request",
          "content": {
              "application/json": {
                  "schema": {
                      "type": "object",
                      "properties": {
                          "error": {
                              "type": "string",
                              "example": "Invalid start_time format. Expected HH:mm:ss or null"
                          }
                      }
                  }
              }
          }
        }
      }
    }
  }
}
