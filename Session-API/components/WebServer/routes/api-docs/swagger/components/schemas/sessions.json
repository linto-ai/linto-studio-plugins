{
    "SessionRequest": {
        "type": "object",
        "properties": {
            "name": {
                "type": "string"
            },
            "scheduleOn": {
                "type": "string",
                "format": "date-time",
                "default": null
            },
            "endOn": {
                "type": "string",
                "format": "date-time",
                "default": null
            },
            "owner": {
                "type": "string",
                "default": null
            },
            "organizationId": {
                "type": "string",
                "default": null
            },
            "visibility": {
              "type": "string",
              "enum": [
                  "public",
                  "organization",
                  "private",
                  "user"
              ],
              "default": "private"
            },
            "autoStart": {
                "type": "boolean",
                "description": "Automatically start the session",
                "default": false
            },
            "autoEnd": {
                "type": "boolean",
                "description": "Automatically end the session",
                "default": false
            },
            "meta": {
                "type": "object",
                "default": null
            },
            "channels": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/ChannelRequest"
                }
            }
        }
    },
    "SessionUpdateRequest": {
        "type": "object",
        "properties": {
            "name": {
                "type": "string"
            },
            "scheduleOn": {
                "type": "string",
                "format": "date-time",
                "default": null
            },
            "endOn": {
                "type": "string",
                "format": "date-time",
                "default": null
            },
            "owner": {
                "type": "string",
                "default": null
            },
            "organizationId": {
                "type": "string",
                "default": null
            },
            "visibility": {
              "type": "string",
              "enum": [
                  "public",
                  "organization",
                  "private",
                  "user"
              ],
              "default": "private"
            },
            "autoStart": {
                "type": "boolean",
                "description": "Automatically start the session",
                "default": false
            },
            "autoEnd": {
                "type": "boolean",
                "description": "Automatically end the session",
                "default": false
            },
            "meta": {
                "type": "object",
                "default": null
            }
        }
    },
    "SessionUpdateRequestWithChannels": {
        "allOf": [
            { "$ref": "#/components/schemas/SessionUpdateRequest" },
            {
                "type": "object",
                "properties": {
                    "channels": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ChannelUpdateRequest"
                        }
                    }
                }
            }
        ]
    },
    "SessionPaginationAnswer": {
        "type": "object",
        "properties": {
            "sessions": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/SessionAnswer"
                }
            },
            "totalItems": {
                "type": "integer",
                "description": "Total number of sessions matching the filters"
            }
        }
    },
    "SessionAnswerBase": {
        "type": "object",
        "properties": {
            "id": {
                "type": "string",
                "format": "uuid"
            },
            "status": {
                "type": "string",
                "enum": [
                    "on_schedule",
                    "ready",
                    "active",
                    "terminated"
                ]
            },
            "name": {
                "type": "string"
            },
            "owner": {
                "type": "string"
            },
            "organizationId": {
                "type": "string"
            },
            "visibility": {
              "type": "string",
              "enum": [
                  "public",
                  "organization",
                  "private",
                  "user"
              ],
              "default": "private"
            },
            "startTime": {
                "type": "string",
                "format": "date-time"
            },
            "endTime": {
                "type": "string",
                "format": "date-time"
            },
            "scheduleOn": {
                "type": "string",
                "format": "date-time"
            },
            "endOn": {
                "type": "string",
                "format": "date-time"
            },
            "erroredOn": {
                "type": "string",
                "format": "date-time"
            },
            "autoStart": {
                "type": "boolean"
            },
            "autoEnd": {
                "type": "boolean"
            },
            "meta": {
                "type": "object",
                "default": null
            }
        }
    },
    "SessionAnswer": {
        "allOf": [
            { "$ref": "#/components/schemas/SessionAnswerBase" },
            {
                "type": "object",
                "properties": {
                    "channels": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ChannelAnswer"
                        }
                    }
                }
            }
        ]
    },
    "SessionAnswerWithCaptions": {
        "allOf": [
            { "$ref": "#/components/schemas/SessionAnswerBase" },
            {
                "type": "object",
                "properties": {
                    "channels": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ChannelAnswerWithCaptions"
                        }
                    }
                }
            }
        ]
    },
    "TranslationEntry": {
        "type": "object",
        "properties": {
            "target": {
                "type": "string",
                "description": "BCP47 language tag"
            },
            "mode": {
                "type": "string",
                "enum": ["discrete", "external"],
                "description": "Translation mode"
            },
            "translator": {
                "type": "string",
                "description": "Translator name (required for external mode)"
            }
        },
        "required": ["target", "mode"]
    },
    "ChannelRequest": {
        "type": "object",
        "properties": {
            "name": {
                "type": "string",
                "description": "The name of the channel"
            },
            "transcriberProfileId": {
                "type": "integer",
                "description": "The id of the channel config"
            },
            "translations": {
                "type": "array",
                "description": "List of translation targets. Accepts BCP47 strings (legacy, converted to discrete mode) or objects with target, mode, and optional translator.",
                "items": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "BCP47 language tag (legacy format, converted to discrete mode)"
                        },
                        {
                            "$ref": "#/components/schemas/TranslationEntry"
                        }
                    ]
                },
                "default": []
            },
            "keepAudio": {
                "type": "boolean",
                "description": "Save audio",
                "default": true
            },
            "diarization": {
                "type": "boolean",
                "description": "Enable diarization",
                "default": false
            },
            "compressAudio": {
              "type": "boolean",
              "description": "Compress audio as MP3 instead of WAV.",
              "default": true
            },
            "enableLiveTranscripts": {
                "type": "boolean",
                "description": "Set to False to disable transcription.",
                "default": true
            },
            "meta": {
                "type": "object",
                "default": null
            }
        }
    },
    "ChannelUpdateRequest": {
        "type": "object",
        "properties": {
            "id": {
                "type": "integer",
                "description": "The id of the channel"
            },
            "name": {
                "type": "string",
                "description": "The name of the channel"
            },
            "transcriberProfileId": {
                "type": "integer",
                "description": "The id of the transcriber profile"
            },
            "translations": {
                "type": "array",
                "description": "List of translation targets. Accepts BCP47 strings (legacy, converted to discrete mode) or objects with target, mode, and optional translator.",
                "items": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "BCP47 language tag (legacy format, converted to discrete mode)"
                        },
                        {
                            "$ref": "#/components/schemas/TranslationEntry"
                        }
                    ]
                },
                "default": []
            },
            "keepAudio": {
                "type": "boolean",
                "description": "Save audio",
                "default": true
            },
            "diarization": {
                "type": "boolean",
                "description": "Enable diarization",
                "default": false
            },
            "compressAudio": {
              "type": "boolean",
              "description": "Compress audio as MP3 instead of WAV."
            },
            "enableLiveTranscripts": {
                "type": "boolean",
                "description": "Set to False to disable transcription.",
                "default": true
            },
            "meta": {
                "type": "object",
                "default": null
            }
        }
    },
    "ChannelAnswer": {
        "type": "object",
        "properties": {
            "id": {
                "type": "integer",
                "description": "The ID of the channel"
            },
            "index": {
                "type": "integer",
                "description": "The index of the channel in the channels list"
            },
            "keepAudio": {
                "type": "boolean",
                "description": "The audio is saved"
            },
            "diarization": {
                "type": "boolean",
                "description": "The diarization is enabled"
            },
            "compressAudio": {
              "type": "boolean",
              "description": "Audio is compressed as MP3 instead of WAV."
            },
            "enableLiveTranscripts": {
                "type": "boolean",
                "description": "Set to False to disable transcription.",
                "default": true
            },
            "transcriberId": {
                "type": "string",
                "description": "The id of the transcriber that is currently transcribing this channel"
            },
            "lastSegmentId": {
                "type": "integer",
                "description": "The id of the last transcription segment received on this channel"
            },
            "name": {
                "type": "string",
                "description": "The name of the channel"
            },
            "languages": {
                "type": "array",
                "description": "The language of the channel as a BCP-47 language tag (fr-FR, en-US, ...) and endpoints",
                "items": {
                    "type": "string"
                }
            },
            "translations": {
                "type": "array",
                "description": "The translations enabled for the channel",
                "items": {
                    "$ref": "#/components/schemas/TranslationEntry"
                }
            },
            "transcriberProfileId": {
                "type": "integer",
                "description": "The id of the channel config"
            },
            "streamEndpoints": {
                "type": "object",
                "description": "The available stream endpoints for this channel",
                "properties": {
                    "srt": {
                        "type": "string",
                        "description": "The stream endpoint for SRT stream"
                    },
                    "rtmp": {
                        "type": "string",
                        "description": "The stream endpoint for RTMP stream"
                    },
                    "ws": {
                        "type": "string",
                        "description": "The stream endpoint for WEBSOCKET stream"
                    }
                }
            },
            "streamStatus": {
                "type": "string",
                "description": "The status of the stream",
                "enum": [
                    "active",
                    "inactive",
                    "errored"
                ]
            },
            "audioFile": {
                "type": "string",
                "description": "URL to the audio file"
            },
            "meta": {
                "type": "object",
                "description": "Custom metadata for the channel"
            }
        }
    },
    "Caption": {
        "type": "object",
        "properties": {
            "segmentId": {
                "type": "integer",
                "description": "Segment identifier"
            },
            "start": {
                "type": "number",
                "description": "Relative start time in seconds within the segment"
            },
            "end": {
                "type": "number",
                "description": "Relative end time in seconds within the segment"
            },
            "text": {
                "type": "string",
                "description": "Transcribed text"
            },
            "astart": {
                "type": "string",
                "format": "date-time",
                "description": "Absolute start time (wall clock)"
            },
            "aend": {
                "type": "string",
                "format": "date-time",
                "description": "Absolute end time (wall clock)"
            },
            "lang": {
                "type": "string",
                "description": "BCP47 language tag of the transcription"
            },
            "locutor": {
                "type": "string",
                "description": "Speaker identifier from diarization"
            }
        }
    },
    "TranslatedCaption": {
        "type": "object",
        "properties": {
            "segmentId": {
                "type": "integer",
                "description": "Segment identifier matching the source caption"
            },
            "targetLang": {
                "type": "string",
                "description": "BCP47 target language tag"
            },
            "text": {
                "type": "string",
                "description": "Translated text"
            }
        }
    },
    "ChannelAnswerWithCaptions": {
        "allOf": [
            { "$ref": "#/components/schemas/ChannelAnswer" },
            {
                "type": "object",
                "properties": {
                    "closedCaptions": {
                        "type": "array",
                        "description": "Transcription captions for this channel",
                        "items": {
                            "$ref": "#/components/schemas/Caption"
                        }
                    },
                    "translatedCaptions": {
                        "type": "object",
                        "description": "Translations grouped by segmentId. Keys are segmentId strings, values are arrays of translations.",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "$ref": "#/components/schemas/TranslatedCaption"
                            }
                        }
                    }
                }
            }
        ]
    },
    "ChannelAnswerWithPaginatedCaptions": {
        "allOf": [
            { "$ref": "#/components/schemas/ChannelAnswerWithCaptions" },
            {
                "type": "object",
                "properties": {
                    "organizationId": {
                        "type": "string",
                        "description": "Organization ID of the parent session"
                    },
                    "visibility": {
                        "type": "string",
                        "description": "Visibility of the parent session",
                        "enum": ["public", "organization", "private", "user"]
                    },
                    "totalClosedCaptions": {
                        "type": "integer",
                        "description": "Total number of closed captions for this channel"
                    },
                    "totalTranslatedCaptions": {
                        "type": "integer",
                        "description": "Total number of distinct segments with translations for this channel"
                    }
                }
            }
        ]
    }

}
